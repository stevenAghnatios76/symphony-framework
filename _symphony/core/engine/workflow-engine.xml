<?xml version="1.0" encoding="UTF-8"?>
<!--
  Symphony Workflow Engine — sequential + ensemble step execution
  See architecture spec §5.1, §6.4, §6.5

  Contract:
    1. Invoked for workflows with execution.mode: sequential OR ensemble
    2. Sequential mode: linear step-by-step execution, single owner agent,
       pauses at each <template-output> under normal interaction mode
    3. Ensemble mode: turn loop over ensemble_participants with
       ensemble_turn_policy (round-robin | facilitator-picks | user-picks);
       user is inside the execution loop as a participant
    4. Honors interaction modes: normal (pause at checkpoints),
       YOLO (auto-proceed, never bypasses gates or self-critique),
       planning (show plan, approve, then normal or YOLO)
    5. Invokes the cross-cutting protocols before/after each step:
       self-critique, trust-levels, anti-rationalization
       (diagnose-then-fix is invoked only on failure)
    6. Persists template-outputs and calls artifact-enrichment-hook after each persist
    7. Writes a checkpoint after each completed step

  Status: stub — runtime implementation lands in Spec 2 Core Engine plan
-->
<workflow-engine version="0.0.1">
  <status>stub</status>
  <supported-execution-modes>
    <mode>sequential</mode>
    <mode>ensemble</mode>
  </supported-execution-modes>
  <supported-interaction-modes>
    <mode>normal</mode>
    <mode>YOLO</mode>
    <mode>planning</mode>
  </supported-interaction-modes>
  <contract>
    <responsibility>step-loop-execution</responsibility>
    <responsibility>ensemble-turn-loop-execution</responsibility>
    <responsibility>template-output-persistence</responsibility>
    <responsibility>invoke-cross-cutting-protocols</responsibility>
    <responsibility>checkpoint-after-each-step</responsibility>
  </contract>
  <spec-reference>docs/superpowers/specs/2026-04-08-symphony-architecture-design.md#51-engine-components</spec-reference>
</workflow-engine>
